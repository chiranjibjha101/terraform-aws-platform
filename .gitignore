# =============================================================================
# .gitignore — terraform-aws-platform
# =============================================================================


# =============================================================================
# TERRAFORM CORE
# =============================================================================

# Local .terraform directories — created by terraform init
# Contains downloaded providers, modules, and backend config
# Never commit — regenerated by terraform init
**/.terraform/*

# Terraform lock file — EXCEPTION: this SHOULD be committed
# It pins exact provider versions so every engineer and CI uses the same binary
# Uncomment the line below only if you intentionally want to ignore it (not recommended)
# .terraform.lock.hcl

# Compiled plan files — contain sensitive data in binary form
# Generated by terraform plan -out=tfplan
*.tfplan
tfplan

# Crash log files — generated when Terraform hits a panic
crash.log
crash.*.log

# Terraform CLI config override files
# These are created locally and should never be shared
override.tf
override.tf.json
*_override.tf
*_override.tf.json


# =============================================================================
# STATE FILES — most important section
# =============================================================================

# Local state files — only exist if using local backend (bootstrap stack only)
# All other stacks use S3 remote state and produce no local state files
*.tfstate
*.tfstate.*
*.tfstate.backup

# tfstate directory if anyone accidentally uses a directory path
.terraform.tfstate


# =============================================================================
# SECRETS AND CREDENTIALS — never commit these
# =============================================================================

# Variable files that may contain secrets
# Use terraform.tfvars for non-sensitive values only
# For secrets: use AWS Secrets Manager or SSM Parameter Store
*.tfvars.json
secrets.tfvars
secret.tfvars
secrets.auto.tfvars
secret.auto.tfvars

# AWS credentials files
.aws/credentials
.aws/config
credentials
*_credentials

# Private keys and certificates
*.pem
*.key
*.p12
*.pfx
*.cer
*.crt
id_rsa
id_rsa.*
id_ed25519
id_ed25519.*

# Environment files that may contain secrets
.env
.env.*
!.env.example


# =============================================================================
# SENSITIVE TFVARS — terraform.tfvars is committed (non-sensitive values)
# but any tfvars with "secret" or "sensitive" in the name is blocked
# =============================================================================

# NOTE: terraform.tfvars IS committed in this repo — it contains only
# non-sensitive values like instance types, CIDR blocks, and feature flags.
# Secrets are fetched at runtime from AWS Secrets Manager via data sources.

# Block any accidentally created sensitive var files
*sensitive*.tfvars
*secret*.tfvars
*password*.tfvars
*credential*.tfvars


# =============================================================================
# CI/CD ARTIFACTS
# =============================================================================

# Saved plan files from CI runs
plans/
*.plan

# Checkov output reports
checkov-report.*
checkov_results.*

# tflint output
.tflint/
tflint-report.*

# terraform-docs output (only if generated outside modules)
# Module READMEs ARE committed — they are generated by pre-commit hooks
# and checked into git as documentation


# =============================================================================
# DEVELOPMENT TOOLS
# =============================================================================

# IDE directories
.idea/
.vscode/
*.swp
*.swo
*~

# VSCode settings — exception: .vscode/extensions.json can be committed
# to recommend extensions to teammates
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

# JetBrains IDEs (IntelliJ, GoLand, etc.)
*.iml
.idea/

# Vim swap files
*.swp
*.swo

# Emacs backup files
*~
\#*\#
.\#*

# macOS system files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Icon?

# Windows system files
desktop.ini
$RECYCLE.BIN/

# Linux temp files
*~


# =============================================================================
# TERRATEST (Go integration tests)
# =============================================================================

# Go build artifacts
tests/integration/vendor/
tests/integration/*.test
*.test

# Go module download cache
go/pkg/
pkg/


# =============================================================================
# TERRAGRUNT (if used alongside Terraform)
# =============================================================================

# Terragrunt cache directories
**/.terragrunt-cache/*
.terragrunt-cache/


# =============================================================================
# TEMPORARY AND LOCAL FILES
# =============================================================================

# Temporary files created during debugging
*.tmp
*.temp
tmp/
temp/

# Local notes and scratch files — keep personal notes out of the repo
scratch.*
notes.*
TODO.local
local.*

# Output files from scripts
output/
outputs/
*.out

# Backup files
*.backup
*.bak
